{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "packages/core/src/**/*",
    "packages/renderer/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/tests/**",
    "**/*.test.ts",
    "**/*.skip.ts"
  ]
}