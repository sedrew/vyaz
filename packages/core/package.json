{
  "name": "@vyaz/core",
  "version": "0.0.8",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "node": "./dist/index.js",
      "browser": "./dist/index.browser.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "browser": {
    "get-system-fonts": false,
    "fs": false,
    "module": false,
    "node:fs": false,
    "child_process": false
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --external @chenglou/pretext --external js-yaml --external @napi-rs/canvas --external fontkit --external get-system-fonts && bun build ./src/index.browser.ts --outdir ./dist --outfile ./dist/index.browser.js --target browser && tsc --project tsconfig.json --emitDeclarationOnly",
    "test": "bun test"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "js-yaml": "^5.0.0"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "fontkit": "^2.0.4",
    "get-system-fonts": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@clean-jsdoc-theme/typedoc": "^5.0.6",
    "typedoc": "^0.28.19"
  }
}
