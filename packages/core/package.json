{
  "name": "@vyaz/core",
  "version": "0.0.4",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "node": "./src/index.ts",
      "browser": "./src/index.browser.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "browser": {
    "get-system-fonts": false,
    "fs": false,
    "module": false,
    "node:fs": false,
    "child_process": false
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@clean-jsdoc-theme/typedoc": "^5.0.6",
    "js-yaml": "^5.0.0",
    "typedoc": "^0.28.19"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "fontkit": "^2.0.4",
    "get-system-fonts": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  }
}
