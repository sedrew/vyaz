{
  "name": "@vyaz/renderer",
  "version": "0.0.11",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "node": "./dist/index.js",
      "browser": "./dist/index.browser.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bun build ./src/index.browser.ts --outdir ./dist --outfile ./dist/index.browser.js --target browser --external @vyaz/core && tsc --project tsconfig.json --emitDeclarationOnly"
  },
  "dependencies": {
    "@vyaz/core": "^0.0.11"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "is-svg": "^6.1.0",
    "svg-parser": "^2.0.4",
    "typescript": "^5.4.0"
  }
}